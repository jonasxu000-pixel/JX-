<!--pages/index/index.wxml - 首页-->
<view class="container">
  <!-- 标题区域 -->
  <view class="header">
    <view class="icon-area">
      <view class="piece-icon black-piece"></view>
      <view class="piece-icon white-piece"></view>
    </view>
    <text class="title">双人五子棋</text>
    <text class="subtitle">好友联机对战</text>
  </view>

  <!-- 单人模式 -->
  <view class="section">
    <text class="section-title">单人模式</text>
    <button class="btn btn-primary" bindtap="onStartGame">
      <text class="btn-text">单机对战</text>
    </button>
  </view>

  <!-- 联机对战 -->
  <view class="section">
    <text class="section-title">联机对战</text>
    <button class="btn btn-secondary" bindtap="onCreateRoom">
      <text class="btn-text">创建房间</text>
    </button>
    <button class="btn btn-tertiary" bindtap="onJoinRoom">
      <text class="btn-text">加入房间</text>
    </button>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="version-text">v1.0</text>
  </view>
</view>

/* pages/index/index.wxss - 首页样式 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

/* 标题区域 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 200rpx;
  margin-bottom: 160rpx;
}

.icon-area {
  display: flex;
  gap: 40rpx;
  margin-bottom: 40rpx;
}

.piece-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.black-piece {
  background: radial-gradient(circle at 35% 35%, #666, #111);
}

.white-piece {
  background: radial-gradient(circle at 35% 35%, #fff, #ccc);
}

.title {
  font-size: 68rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 6rpx;
}

.subtitle {
  font-size: 30rpx;
  color: #a0a0b0;
  margin-top: 16rpx;
  letter-spacing: 4rpx;
}

/* 功能按钮 */
.action-section {
  width: 75%;
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #4a90d9 0%, #357abd 100%);
  box-shadow: 0 6rpx 20rpx rgba(74, 144, 217, 0.4);
}

.btn-text {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 底部信息 */
.footer {
  position: fixed;
  bottom: 60rpx;
}

.version-text {
  font-size: 24rpx;
  color: #555;
}

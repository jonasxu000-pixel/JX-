/* pages/room/create.wxss - 创建房间页面样式 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 0 40rpx;
}

.hidden {
  display: none;
}

.content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  margin-top: 120rpx;
  transition: opacity 0.3s;
}

/* 图标 */
.icon-wrapper {
  margin-bottom: 40rpx;
}

.room-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4a90d9 0%, #357abd 100%);
  box-shadow: 0 12rpx 32rpx rgba(74, 144, 217, 0.4);
  position: relative;
}

.room-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 50rpx;
  height: 50rpx;
  border: 6rpx solid #fff;
  border-radius: 50%;
}

/* 标题 */
.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.title-small {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 28rpx;
  color: #a0a0b0;
  margin-bottom: 80rpx;
}

/* 房间号卡片 */
.room-id-card {
  width: 80%;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  backdrop-filter: blur(10rpx);
}

.room-id-label {
  font-size: 26rpx;
  color: #a0a0b0;
  margin-bottom: 16rpx;
}

.room-id-value {
  font-size: 80rpx;
  font-weight: bold;
  color: #4a90d9;
  letter-spacing: 12rpx;
  font-family: 'Courier New', monospace;
}

.room-id-hint {
  font-size: 24rpx;
  color: #666;
  margin-top: 16rpx;
}

/* 按钮 */
.btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #4a90d9 0%, #357abd 100%);
  box-shadow: 0 6rpx 20rpx rgba(74, 144, 217, 0.4);
}

.btn-text {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
}

.btn-back {
  background: transparent;
  margin-top: 40rpx;
}

.btn-back-text {
  font-size: 28rpx;
  color: #888;
}

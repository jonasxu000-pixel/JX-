/* pages/room/join.wxss - 加入房间页面样式 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 0 40rpx;
}

.content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  margin-top: 120rpx;
}

/* 图标 */
.icon-wrapper {
  margin-bottom: 40rpx;
}

.join-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #50c878 0%, #3da85f 100%);
  box-shadow: 0 12rpx 32rpx rgba(80, 200, 120, 0.4);
  position: relative;
}

.join-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 44rpx;
  height: 44rpx;
  border: 6rpx solid #fff;
  border-radius: 50%;
}

.join-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 58%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 6rpx;
  background: #fff;
  border-radius: 3rpx;
}

/* 标题 */
.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 28rpx;
  color: #a0a0b0;
  margin-bottom: 60rpx;
}

/* 输入卡片 */
.input-card {
  width: 85%;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  backdrop-filter: blur(10rpx);
}

.input-label {
  font-size: 26rpx;
  color: #a0a0b0;
  margin-bottom: 20rpx;
}

.room-input {
  position: absolute;
  opacity: 0;
  width: 200rpx;
  height: 60rpx;
}

.input-display {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.char {
  width: 64rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: bold;
  color: #4a90d9;
  border-bottom: 4rpx solid #333;
  font-family: 'Courier New', monospace;
}

.char.filled {
  border-bottom-color: #4a90d9;
  color: #fff;
}

.placeholder {
  color: #555;
  font-size: 28rpx;
}

/* 按钮 */
.btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #50c878 0%, #3da85f 100%);
  box-shadow: 0 6rpx 20rpx rgba(80, 200, 120, 0.4);
}

.btn-disabled {
  background: rgba(255, 255, 255, 0.1);
  box-shadow: none;
}

.btn-text {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
}

.btn-disabled .btn-text {
  color: #888;
}

.btn-back {
  background: transparent;
  margin-top: 40rpx;
}

.btn-back-text {
  font-size: 28rpx;
  color: #888;
}

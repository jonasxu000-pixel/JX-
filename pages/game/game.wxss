/* pages/game/game.wxss - 游戏页面样式 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.status-bar {
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 30rpx 0 10rpx;
}

.status-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
